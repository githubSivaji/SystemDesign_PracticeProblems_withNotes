      "fontFamily": 8,
      "text": "Design a Rate Limiter",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Design a Rate Limiter",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "-i0ZpwwULN_ZTgqVv31-V",
      "type": "text",
      "x": -41.775028899895915,
      "y": -8.970852843550574,
      "width": 1199,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a1",
      "roundness": null,
      "seed": 429855996,
      "version": 292,
      "versionNonce": 591775940,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1755277671404,
      "link": null,
      "locked": false,
      "text": "A rate limiter controls how many requests a client can make within a specific timeframe. \nIt acts like a traffic controller for your API - allowing, for example, 100 requests per minute from a user, \nthen rejecting excess requests with an HTTP 429 \"Too Many Requests\" response. Rate limiters prevent abuse, \nprotect your servers from being overwhelmed by bursts of traffic, and ensure fair usage across all users.\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A rate limiter controls how many requests a client can make within a specific timeframe. \nIt acts like a traffic controller for your API - allowing, for example, 100 requests per minute from a user, \nthen rejecting excess requests with an HTTP 429 \"Too Many Requests\" response. Rate limiters prevent abuse, \nprotect your servers from being overwhelmed by bursts of traffic, and ensure fair usage across all users.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
