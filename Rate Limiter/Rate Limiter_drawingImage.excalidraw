      "isDeleted": false,
      "boundElements": [],
      "updated": 1755278389443,
      "link": null,
      "locked": false,
      "text": "Functional Requirements\n- identify users by id, IP, or api key\n- limit requests based on configurable rules \n- return proper error headers and status codes ",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional Requirements\n- identify users by id, IP, or api key\n- limit requests based on configurable rules \n- return proper error headers and status codes ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "gQ8cc9TSMjBpGavnVDqNk",
      "type": "text",
      "x": 0.24821135424377871,
      "y": 830.1537541658538,
      "width": 440,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ab",
      "roundness": null,
      "seed": 1419220988,
      "version": 178,
      "versionNonce": 867013116,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1755278733561,
      "link": null,
      "locked": false,
      "text": "Scale\n- 100M DAU\n- 1M rps\n\n\n\nNon-functional Requirements\n- availability >> consistency\n- low latency rate limit checks (< 10ms)\n- scalable to 1M rps",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Scale\n- 100M DAU\n- 1M rps\n\n\n\nNon-functional Requirements\n- availability >> consistency\n- low latency rate limit checks (< 10ms)\n- scalable to 1M rps",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
