      "boundElements": [],
      "updated": 1755293836137,
      "link": null,
      "locked": false,
      "text": "1. request come in\n2. gateway fetch token and last_refill_time from \nredis HMGET alice:bucket tokens last_refill\n3. Update counts based on rate and last refill\n4. Responsd pass or fail based on if tokens > 0\n5. Update bucket status",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. request come in\n2. gateway fetch token and last_refill_time from \nredis HMGET alice:bucket tokens last_refill\n3. Update counts based on rate and last refill\n4. Responsd pass or fail based on if tokens > 0\n5. Update bucket status",
      "autoResize": true,
      "lineHeight": 1.25
    },
